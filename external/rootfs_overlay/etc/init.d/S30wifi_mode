#!/bin/sh
#
# Select wlan0 STA vs AP mode based on /etc/aa-proxy-rs/config.toml
# (via /var/run/aa-proxy-wifi.env generated by S28aa-proxy-wifi).
#

set -e

CONFIG="${AA_PROXY_RS_CONFIG:-/etc/aa-proxy-rs/config.toml}"
DAEMON="/usr/bin/aa-proxy-rs"

load_wifi_env() {
	if [ -f /var/run/aa-proxy-wifi.env ]; then
		# shellcheck disable=SC1091
		. /var/run/aa-proxy-wifi.env
	elif [ -x "$DAEMON" ]; then
		"$DAEMON" -c "$CONFIG" --generate-wifi-env
		# shellcheck disable=SC1091
		. /var/run/aa-proxy-wifi.env
	else
		echo "Missing /var/run/aa-proxy-wifi.env and $DAEMON"
		exit 1
	fi
}

case "$1" in
	start)
		load_wifi_env

		WIFI_MODE="${WIFI_MODE:-ap}"
		IFACE="${IFACE:-wlan0}"
		AP_IP="${AP_IP:-10.0.0.1}"
		AP_MASK="${AP_MASK:-255.255.255.0}"

		killall -q hostapd dnsmasq wpa_supplicant || true
		ifdown "$IFACE" 2>/dev/null || true

		if [ "$WIFI_MODE" = "sta" ]; then
			if [ -z "${WIFI_BSSID:-}" ]; then
				echo "wifi_bssid must be set in config.toml for STA mode; falling back to AP mode"
				WIFI_MODE="ap"
			fi
		fi

		if [ "$WIFI_MODE" = "ap" ]; then
			echo "Configuring $IFACE for AP mode (${AP_IP}/${AP_MASK})"

			cat > /etc/network/interfaces <<EOF
auto lo
iface lo inet loopback

auto ${IFACE}
iface ${IFACE} inet static
  address ${AP_IP}
  netmask ${AP_MASK}
EOF
		else
			if [ -z "${SSID:-}" ]; then
				echo "ssid must be set in config.toml for STA mode"
				exit 1
			fi

			echo "Configuring $IFACE for STA mode (SSID=${SSID})"

			if [ -x "$DAEMON" ]; then
				"$DAEMON" -c "$CONFIG" --generate-wpa-conf
			fi

			WPA_CONF="/var/run/wpa_supplicant.conf"
			if [ ! -f "$WPA_CONF" ]; then
				WPA_CONF="/etc/wpa_supplicant.conf"
			fi

			cat > /etc/network/interfaces <<EOF
auto lo
iface lo inet loopback

auto ${IFACE}
iface ${IFACE} inet dhcp
  pre-up wpa_supplicant -D nl80211 -i ${IFACE} -c ${WPA_CONF} -B
  post-down killall -q wpa_supplicant
EOF
		fi
		;;
	*)
		echo "Usage: $0 {start}"
		exit 1
		;;
esac

exit 0
